@model IEnumerable<EmployeeDepartmentMVC.Models.Department>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DepartmentName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Location)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DepartmentName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Location)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.DepartmentId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.DepartmentId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.DepartmentId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>




@if (ViewBag.ProcessList != null && ViewBag.ProcessList.Count > 0){
<div class="alert alert-info">
    <h4>Chrome Browser Processes:</h4>
    <ul>
        @foreach (var processInfo in ViewBag.ProcessList)
        {
            <li>@processInfo</li>
        }
    </ul>
</div>
}
else
{
<div class="alert alert-warning">
    No Chrome browser processes found.
</div>
}